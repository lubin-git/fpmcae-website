  "intro": {
    "title": "简介",
    "content": "FPMCAE是由浙江大学罗尧治教授团队自主研发的通用结构复杂行为仿真分析软件。采用有限质点法作为核心算法，集成了前后处理功能和多种求解器引擎，并融入了并行计算技术。"
  },
  "features": {
    "title": "功能",
    "items": [
      {
        "title": "核心算法",
        "desc": "有限质点法，高效进行结构复杂行为的仿真分析。"
      },
      {
        "title": "前后处理功能",
        "desc": "强大的数据输入和结果分析工具。"
      },
      {
        "title": "多种求解器引擎",
        "desc": "支持多种类型的求解器，满足不同仿真需求。"
      },
      {
        "title": "并行计算",
        "desc": "集成技术提升计算效率，适合大规模模拟。"
      }
    ]
  },
